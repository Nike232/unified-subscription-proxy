# Deprecated compatibility wrapper. Prefer apps/control-plane/Dockerfile.
FROM golang:1.24-alpine AS build
WORKDIR /src
COPY . .
RUN go build -o /out/control-plane ./apps/control-plane

FROM alpine:3.21
WORKDIR /app
COPY --from=build /out/control-plane /app/control-plane
COPY apps/web /app/apps/web
EXPOSE 8080
CMD ["/app/control-plane"]
